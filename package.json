{
  "name": "@codetypess/xlsx-ts",
  "version": "0.2.2",
  "description": "A lossless-first XLSX reader/writer prototype that preserves styles and untouched package parts.",
  "type": "module",
  "license": "MIT",
  "author": "codetypes",
  "repository": {
    "type": "git",
    "url": "https://github.com/codetypess/xlsx-ts.git"
  },
  "homepage": "https://github.com/codetypess/xlsx-ts#readme",
  "bugs": {
    "url": "https://github.com/codetypess/xlsx-ts/issues"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "bin": {
    "xlsx-ts": "./dist/src/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "node --import tsx scripts/clean-dist.ts",
    "build": "npm run clean && tsc -p tsconfig.json",
    "cli": "node --import tsx src/cli.ts",
    "pack:check": "node --import tsx scripts/check-pack.ts",
    "test": "node --import tsx --test test/**/*.test.ts",
    "prepublishOnly": "npm run build && npm test && npm run pack:check",
    "release": "npm publish --access public",
    "bench:monster": "node --import tsx scripts/benchmark.ts res/monster.xlsx",
    "bench:check": "node --import tsx scripts/benchmark.ts res/monster.xlsx 5 --check benchmarks/monster-baseline.json",
    "validate:roundtrip": "node --import tsx scripts/validate-roundtrip.ts",
    "validate:task": "npm run validate:roundtrip -- res/task.xlsx"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "fflate": "^0.8.2"
  }
}
